\ProvidesPackage{src/title}[2024/01/31 v.01 Titlepage for VPD Subject]

\usepackage{paracol}                    % Пакет для поддержки многоколоночного текста
\usepackage{geometry}

\geometry{top=2cm, left=2cm, right=2cm, left=2cm}

% Custom implementation of author and affiliation to avoid authblk dependency
\def\@customauthor{}
\def\@customaffil{}

% Redefine author to store value
\renewcommand{\author}[1]{\gdef\@customauthor{#1}}

% Define affil to store value (simple version for single author block)
\newcommand{\affil}[1]{\gdef\@customaffil{#1}}

% Local definitions
\newcommand{\supervisor}[1]{\gdef\@supervisor{#1}}
\newcommand{\@supervisor}{Имя О. Фамилия}

\renewcommand{\abstract}[1]{\gdef\@abstract{#1}}
\newcommand{\@abstract}{
Опишите здесь что вы сделали в работе с точки зрения исследования. Что вы для себя открыли? С какими трудностями столкнулись? Какие технологии использовали?
}

\newcommand{\keywords}[1]{\gdef\@keywords{#1}}
\newcommand{\@keywords}{
подберите 3-5 ключевых слова, отличающих эту работу от всех остальных
}

\renewcommand\maketitle{

    \begin{titlepage}

        \vspace*{1cm}

        \begin{center}

            % Add ITMO University Logo
            % \includegraphics[height=2cm]{images/logo_basic_russian_black.pdf}
            {\large \bfseries УНИВЕРСИТЕТ ИТМО}

            \vspace{3mm}

            % The faculty name
            Факультет Систем Управления и Робототехники

            \vspace{4cm}

            % Add lab work title
            {\Large \bfseries \MakeUppercase{\@title}}

        \end{center}

        \vspace{3cm}

        % Setup abstract with authors
        \columnratio{0.7, 0.3}
        \columnsep = 1cm
        \begin{paracol}{2}
            \begin{leftcolumn}
                \textbf{Аннотация} -- \@abstract

                \vspace{1em}

                \noindent
                \textbf{Ключевые слова}: \@keywords
            \end{leftcolumn}

            \begin{rightcolumn}
                \setlength{\parindent}{0cm}

                \textbf{Выполнили}
                \vspace{1em}

                {\@customauthor} \\
                {\itshape \small \@customaffil}

                \vspace{1em}

                \textbf{Проверил}
                \vspace{1em}

                {\@supervisor}

            \end{rightcolumn}
        \end{paracol}


        \vfill

        \begin{center}
            \@date
        \end{center}

    \end{titlepage}

}

